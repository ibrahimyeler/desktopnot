{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NotApp",
  "version": "1.2.2",
  "identifier": "com.notapp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NotApp",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src 'self' http://72.61.155.171:* https://api.github.com https://github.com tauri:; img-src 'self' data: blob: https:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwMTcwQzQ5MzRFNTZDMApSV1RBVms2VHhIQUJCcEY1aVVNdUFSNUhCNTZ2ZGRiOE9DdHdmaTVUTElucHExQlZ6eHVtckgzUwo=",
      "endpoints": [
        "https://github.com/ibrahimyeler/desktopnot/releases/latest/download/latest.json"
      ]
    }
  }
}

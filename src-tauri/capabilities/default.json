{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "dialog:default",
    "process:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://72.61.155.171:*" },
        { "url": "https://72.61.155.171" }
      ]
    }
  ]
}

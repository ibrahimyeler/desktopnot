# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost
API_VERSION=v1

# API Base URLs for different panels
CUSTOMER_BASE_URL=http://localhost:8080/api/v1/customer
SELLER_BASE_URL=http://localhost:8080/api/v1/seller
ADMIN_BASE_URL=http://localhost:8080/api/v1/admin

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=randevu_db
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRY=24h

# Environment
ENV=development
